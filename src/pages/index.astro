---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: 'Zero-cost integration',
    body: 'Skip the dev cycle. Your agency, CMS plugin, or marketing team pastes a single snippet — and you are collecting data the same day. No engineering project, no roadmap fight.',
  },
  {
    title: 'Heatmaps that explain',
    body: 'See which segments viewers re-watch and where they bounce. Per-source, per-tenant, real time.',
  },
  {
    title: 'You own your data',
    body: 'Your viewer data is yours. Export it, plug it into the BI tools your team already uses, hand it to marketing for campaign reporting. We never sell, share, or repackage it.',
  },
];

const stats = [
  { value: 'Seconds', label: 'From viewer play to your dashboard.' },
  { value: 'Zero PII', label: 'No cookies, no fingerprints, no identifiers.' },
  { value: '< 5 min', label: 'From sign-up to first event ingested.' },
  { value: '100%', label: 'First-party data — yours, not ours.' },
];

const valueProps = [
  'Privacy by design. No cookies, no fingerprints, no personal data — Vidalyy watches videos, not people. Ship in regulated markets like the EU and California without a consent banner for basic analytics.',
  'Built to scale, ready on day one. Backed by the same class of infrastructure powering the world\u2019s largest analytics platforms. Dashboards stay fast whether you have one video or a million.',
  'Enterprise security, included. Encryption in transit and at rest, scoped access controls, audit-friendly logs. Hand the security review to your IT team — they\u2019ll find what they are looking for.',
];
---

<Layout>
  <header id="site-header" class="nav-bar fixed inset-x-0 top-0 z-30">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
      <a href="/" class="text-lg font-semibold tracking-tight">Vidalyy</a>
      <nav class="flex items-center gap-6 text-sm">
        <a href="#features" class="hidden text-(--color-muted-foreground) transition-colors hover:text-(--color-foreground) sm:inline">Features</a>
        <a href="#why" class="hidden text-(--color-muted-foreground) transition-colors hover:text-(--color-foreground) sm:inline">Why</a>
        <a href="#how" class="hidden text-(--color-muted-foreground) transition-colors hover:text-(--color-foreground) sm:inline">How it works</a>
        <a href="https://app.vidalyy.com" class="header-cta rounded-md border border-(--color-accent)/40 bg-(--color-accent)/10 px-3 py-1.5 text-(--color-accent) transition-colors hover:bg-(--color-accent)/20">Get started</a>
      </nav>
    </div>
  </header>

  <main>
    <section id="hero" class="relative flex min-h-screen items-center overflow-hidden bg-black text-white">
      <video
        id="hero-video"
        class="absolute inset-0 h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-hidden="true"
      >
        <source src={`${import.meta.env.BASE_URL}hero.mp4`} type="video/mp4" />
      </video>
      <div
        class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/55 to-black/80"
        aria-hidden="true"
      >
      </div>
      <div
        id="hero-content"
        class="relative z-10 mx-auto w-full max-w-5xl px-6 py-24 sm:py-32"
      >
        <p class="mb-6 inline-flex items-center rounded-full border border-white/20 bg-white/10 px-3.5 py-1.5 text-sm text-white/80 backdrop-blur-sm">
          Currently in alpha
        </p>
        <h1 class="text-balance text-4xl font-semibold tracking-tight sm:text-6xl">
          Drop-in video analytics, powered by <span class="shimmer">AI</span>.
        </h1>
        <p class="mt-6 max-w-2xl text-pretty text-xl leading-relaxed text-white/80">
          Vidalyy turns a single script tag into per-video heatmaps and
          retention metrics — with AI surfacing the patterns and
          recommendations your team would otherwise spend a quarter chasing.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href="https://app.vidalyy.com"
            class="group inline-flex items-center gap-2 rounded-md bg-(--color-accent) px-6 py-3 text-base font-medium text-(--color-accent-foreground) shadow-[0_0_30px_-8px_var(--color-accent-glow)] transition-all hover:brightness-110 hover:shadow-[0_0_40px_-4px_var(--color-accent-glow)]"
          >
            Start in 5 minutes
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
          </a>
          <a
            href="#how"
            class="inline-flex items-center rounded-md border border-white/20 bg-white/5 px-6 py-3 text-base font-medium text-white backdrop-blur-sm transition-colors hover:border-white/40 hover:bg-white/10"
          >
            How it works
          </a>
        </div>
      </div>
      <a
        href="#features"
        aria-label="Scroll to features"
        class="scroll-cue absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-white/70 hover:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M6 9l6 6 6-6"></path>
        </svg>
      </a>
    </section>

    <section id="features" class="relative scroll-mt-20 border-t border-(--color-border)/60">
      <div class="mx-auto max-w-5xl px-6 py-24">
        <h2 class="reveal text-3xl font-semibold tracking-tight sm:text-4xl">What you get</h2>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            features.map((f, i) => (
              <article
                class="reveal card-surface group relative rounded-xl p-7 transition-all hover:border-(--color-border-strong)"
                style={`transition-delay: ${i * 120}ms`}
              >
                <h3 class="text-xl font-semibold tracking-tight">{f.title}</h3>
                <p class="mt-3 text-base leading-relaxed text-(--color-muted-foreground)">{f.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="why" class="relative scroll-mt-20 border-t border-(--color-border)/60">
      <div class="mx-auto max-w-5xl px-6 py-24">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
          <div>
            <p class="reveal text-base font-semibold uppercase tracking-[0.22em] text-(--color-accent) sm:text-lg">
              Near real-time · Data-driven · Actionable
            </p>
            <h2 class="reveal mt-5 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
              See what your audience is watching — the moment they watch it.
              <span class="block text-(--color-muted-foreground)">
                And know what to do next.
              </span>
            </h2>
            <p class="reveal mt-7 max-w-xl text-pretty text-lg leading-relaxed text-(--color-muted-foreground)">
              Every play, pause, and rewind lands in your dashboard within
              seconds. Stop waiting on end-of-month reports — spot the scenes
              that grab attention, the ones that lose viewers, and the
              videos worth promoting while the campaign is still running and
              the decision still matters.
            </p>
            <ul class="mt-10 space-y-5">
              {
                valueProps.map((p, i) => (
                  <li
                    class="reveal flex gap-3 text-base leading-relaxed text-(--color-muted-foreground)"
                    style={`transition-delay: ${i * 100}ms`}
                  >
                    <svg
                      class="mt-1.5 h-5 w-5 flex-none text-(--color-accent)"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.5 7.6a1 1 0 0 1-1.426 0L3.29 9.71a1 1 0 1 1 1.42-1.41l3.78 3.81 6.79-6.83a1 1 0 0 1 1.42 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span class="text-(--color-foreground)/90">{p}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="grid grid-cols-2 gap-4 self-start lg:gap-6">
            {
              stats.map((s, i) => (
                <div
                  class="reveal card-surface relative overflow-hidden rounded-xl p-6"
                  style={`transition-delay: ${i * 90}ms`}
                >
                  <div
                    aria-hidden="true"
                    class="pointer-events-none absolute -top-12 -right-12 h-28 w-28 rounded-full bg-(--color-accent)/10 blur-2xl"
                  />
                  <div class="relative">
                    <div class="text-3xl font-semibold tracking-tight text-(--color-accent) sm:text-4xl">
                      {s.value}
                    </div>
                    <p class="mt-3 text-sm leading-relaxed text-(--color-muted-foreground)">
                      {s.label}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="how" class="scroll-mt-20 border-t border-(--color-border)/60">
      <div class="mx-auto max-w-5xl px-6 py-24">
        <h2 class="reveal text-3xl font-semibold tracking-tight sm:text-4xl">How it works</h2>
        <ol class="mt-12 space-y-8">
          <li class="reveal flex gap-5" style="transition-delay: 80ms">
            <span class="mt-0.5 inline-flex h-9 w-9 flex-none items-center justify-center rounded-full border border-(--color-accent)/40 bg-(--color-accent)/10 text-base font-semibold text-(--color-accent)">1</span>
            <div>
              <p class="text-lg font-medium">Sign in and create an organization.</p>
              <p class="mt-2 text-base leading-relaxed text-(--color-muted-foreground)">
                We mint a per-tenant ingest token and assign a tracking id automatically.
              </p>
            </div>
          </li>
          <li class="reveal flex gap-5" style="transition-delay: 160ms">
            <span class="mt-0.5 inline-flex h-9 w-9 flex-none items-center justify-center rounded-full border border-(--color-accent)/40 bg-(--color-accent)/10 text-base font-semibold text-(--color-accent)">2</span>
            <div class="min-w-0 flex-1">
              <p class="text-lg font-medium">Drop the loader on your page.</p>
              <p class="mt-2 text-base leading-relaxed text-(--color-muted-foreground)">
                Paste this once in your <code>&lt;head&gt;</code>, replacing <code>VIDALY_ID</code> with your tracking id.
                Every <code>&lt;video&gt;</code> on the page gets watched-segment tracking automatically.
              </p>
              <pre class="card-surface mt-4 overflow-x-auto rounded-md p-5 text-sm leading-relaxed text-(--color-foreground)/90"><code>{`<script src="https://collector.vidalyy.com/loader.min.js" data-vidaly-id="VIDALY_ID" async></script>`}</code></pre>
            </div>
          </li>
          <li class="reveal flex gap-5" style="transition-delay: 240ms">
            <span class="mt-0.5 inline-flex h-9 w-9 flex-none items-center justify-center rounded-full border border-(--color-accent)/40 bg-(--color-accent)/10 text-base font-semibold text-(--color-accent)">3</span>
            <div>
              <p class="text-lg font-medium">Watch the dashboard fill in.</p>
              <p class="mt-2 text-base leading-relaxed text-(--color-muted-foreground)">
                Segment heatmaps, lifecycle events, and per-source retention update in real time as visitors watch.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <section id="get-started" class="relative scroll-mt-20 border-t border-(--color-border)/60">
      <div class="mx-auto max-w-3xl px-6 py-24 text-center">
        <p class="reveal text-base font-semibold uppercase tracking-[0.22em] text-(--color-accent) sm:text-lg">
          Get started
        </p>
        <h2 class="reveal mt-5 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
          Sign in and start tracking in under five minutes.
        </h2>
        <p class="reveal mt-6 text-pretty text-lg leading-relaxed text-(--color-muted-foreground)">
          Create an organization, copy the loader, paste it into your site. No
          credit card, no sales call.
        </p>

        <div class="reveal mt-10">
          <a
            href="https://app.vidalyy.com"
            class="group inline-flex items-center gap-2 rounded-md bg-(--color-accent) px-6 py-3 text-base font-medium text-(--color-accent-foreground) shadow-[0_0_30px_-8px_var(--color-accent-glow)] transition-all hover:brightness-110 hover:shadow-[0_0_40px_-4px_var(--color-accent-glow)]"
          >
            Start in 5 minutes
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const prefersReduced = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
      );

      // Hero video play/pause based on reduced-motion preference.
      const video = document.getElementById('hero-video');
      if (video) {
        const apply = () => {
          if (prefersReduced.matches) video.pause();
          else video.play().catch(() => {});
        };
        apply();
        prefersReduced.addEventListener('change', apply);
      }

      // Scroll-reveal via IntersectionObserver.
      const targets = document.querySelectorAll('.reveal');
      if (targets.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in-view');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
        );
        targets.forEach((t) => io.observe(t));
      }

      // Header transparency toggle — opaque after any scroll past the top.
      const header = document.getElementById('site-header');
      const updateHeader = () => {
        if (!header) return;
        header.classList.toggle('is-scrolled', window.scrollY > 8);
      };
      updateHeader();
      window.addEventListener('scroll', updateHeader, { passive: true });

      // Hero parallax — disabled for reduced motion.
      if (prefersReduced.matches) return;
      const heroContent = document.getElementById('hero-content');
      if (!video && !heroContent) return;

      const fadeRange = () => Math.max(window.innerHeight * 0.75, 400);

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const y = window.scrollY;
          if (video) {
            video.style.transform = `translate3d(0, ${y * 0.3}px, 0) scale(1.25)`;
          }
          if (heroContent) {
            heroContent.style.transform = `translate3d(0, ${y * -0.18}px, 0)`;
            heroContent.style.opacity = String(Math.max(0, 1 - y / fadeRange()));
          }
          ticking = false;
        });
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>

  <footer class="border-t border-(--color-border)/60">
    <div class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-3 px-6 py-10 text-sm text-(--color-muted-foreground) sm:flex-row sm:items-center">
      <span>© {new Date().getFullYear()} Vidalyy</span>
      <a href="mailto:dev@peterczibik.com" class="transition-colors hover:text-(--color-foreground)">
        dev@peterczibik.com
      </a>
    </div>
  </footer>
</Layout>
